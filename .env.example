# 本文件仅作模板。请复制到「仓库根目录」并命名为 .env（不要放在 backend/ 下）。
# 首次使用也可不建 .env，由桌面端设置向导写入；勿使用被后端拒绝的不安全默认账号组合。
#
# 必填（向导模式期间可暂缺，此时分析接口不可用直至配齐并重启）
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=school_chicago_crime

# 监听与联启（start.py / uvicorn）
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_DEV_PORT=5173

# 可选：日志与性能（不设则使用代码内默认值）
# LOG_LEVEL=INFO
# CACHE_TTL_SECONDS=600
# CACHE_MAX_ENTRIES=512
# SLOW_QUERY_THRESHOLD_MS=800

# 可选：额外允许的 CORS 来源（逗号分隔，会与内置开发默认值合并）
# CORS_ALLOWED_ORIGINS=http://localhost:5174,https://example.test

# 可选：打包/桌面运行时指定可写数据目录（含 .env）；开发环境通常不需要
# CHICAGO_CRIME_DATA_DIR=
