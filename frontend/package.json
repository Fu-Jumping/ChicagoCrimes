{
  "name": "frontend",
  "version": "1.0.4",
  "description": "An Electron application with React and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "typecheck:strict": "npm run lint && npm run typecheck",
    "i18n:scan": "node ./scripts/i18n-scan.mjs",
    "test:unit": "vitest run src/renderer/src/components/DataStatePanel.test.tsx src/renderer/src/components/SetupWizard.test.tsx src/renderer/src/contexts/GlobalFiltersContext.test.tsx src/renderer/src/utils/heatmapIntensity.test.ts src/renderer/src/utils/locationTypeMap.test.ts src/renderer/src/utils/sidebarFilters.test.ts src/renderer/src/utils/districtBoundaries.test.ts src/renderer/src/utils/filterParams.test.ts src/renderer/src/hooks/useDebouncedValue.test.tsx src/renderer/src/views/MapView.test.tsx src/renderer/src/i18n/index.test.ts",
    "test:ui": "vitest run src/renderer/src/components/AppLayout.test.tsx",
    "test:visual": "vitest run src/renderer/src/tests/visual-regression.test.tsx",
    "test": "npm run test:unit && npm run test:ui && npm run test:visual",
    "perf:benchmark": "node ./scripts/perf-benchmark.mjs",
    "perf:benchmark:ci": "node ./scripts/perf-benchmark-ci.mjs",
    "gate:regression": "npm run typecheck && npm run i18n:scan && npm run test && npm run perf:benchmark",
    "gate:release": "npm run typecheck:strict && npm run i18n:scan && npm run test && npm run perf:benchmark:ci",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource/space-grotesk": "^5.2.10",
    "antd": "^6.3.4",
    "axios": "^1.13.6",
    "d3": "^7.9.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/d3": "^7.4.3",
    "@types/file-saver": "^2.0.7",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.heat": "^0.2.5",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^27.0.1",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^3.2.4"
  }
}
